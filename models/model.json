{
    "rdbms": "mysql",
    "host": "192.168.166.91",
    "port": 3306,
    "dbname": "yaroserverdb",
    "user": "root",
    "passwd": "123456",
    "tables": [
        "user",
        "device",
        "friend",
        "friend_request",
        "group",
        "group_member",
        "offline_message",
        "moment",
        "moment_like",
        "moment_comment"
    ],
    "convert": {
        "enabled": false
    },
    "relationships": {
        "enabled": true,
        "items": [
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "device",
                "target_key": "user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "friend",
                "target_key": "user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "friend_request",
                "target_key": "from_user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "group",
                "target_key": "owner_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "group_member",
                "target_key": "user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "offline_message",
                "target_key": "to_user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "user",
                "original_key": "id",
                "target_table_name": "moment",
                "target_key": "user_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "moment",
                "original_key": "id",
                "target_table_name": "moment_like",
                "target_key": "moment_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "moment",
                "original_key": "id",
                "target_table_name": "moment_comment",
                "target_key": "moment_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "group",
                "original_key": "id",
                "target_table_name": "group_member",
                "target_key": "group_id",
                "enable_reverse": true
            },
            {
                "type": "has many",
                "original_table_name": "friend",
                "original_key": "user_id",
                "target_table_name": "friend",
                "target_key": "friend_id",
                "enable_reverse": true
            }
        ]
    },
    "restful_api_controllers": {
        "enabled": true,
        "resource_uri": "/api/v1/*",
        "class_name": "Restful*Ctrl",
        "filters": [
            "AuthFilter"
        ],
        "db_client": {
            "name": "serverDb",
            "is_fast": false
        },
        "directory": "controllers",
        "generate_base_only": false
    }
}